{
  "$schema": "https://ainative.business/schemas/design-tokens.json",
  "version": "2.0.0",
  "system": "calm-ops",
  "color": {
    "background": {
      "light": "oklch(0.985 0.004 250)",
      "dark": "oklch(0.14 0.02 250)"
    },
    "foreground": {
      "light": "oklch(0.14 0.02 250)",
      "dark": "oklch(0.92 0.01 250)"
    },
    "primary": {
      "light": "oklch(0.50 0.20 260)",
      "dark": "oklch(0.65 0.20 260)"
    },
    "destructive": {
      "light": "oklch(0.55 0.22 25)",
      "dark": "oklch(0.60 0.22 25)"
    },
    "surface": {
      "1": { "light": "oklch(1 0 0)", "dark": "oklch(0.18 0.02 250)" },
      "2": { "light": "oklch(0.975 0.004 250)", "dark": "oklch(0.16 0.02 250)" },
      "3": { "light": "oklch(0.96 0.006 250)", "dark": "oklch(0.14 0.02 250)" }
    },
    "border": {
      "default": { "light": "oklch(0.90 0.006 250)", "dark": "oklch(0.26 0.015 250)" },
      "subtle": { "light": "oklch(0.93 0.004 250)", "dark": "oklch(0.22 0.01 250)" },
      "strong": { "light": "oklch(0.82 0.01 250)", "dark": "oklch(0.32 0.02 250)" }
    },
    "status": {
      "running": { "light": "oklch(0.50 0.20 260)", "dark": "oklch(0.65 0.20 260)" },
      "completed": { "light": "oklch(0.52 0.17 165)", "dark": "oklch(0.62 0.17 165)" },
      "failed": { "light": "oklch(0.55 0.22 25)", "dark": "oklch(0.65 0.22 25)" },
      "warning": { "light": "oklch(0.65 0.18 75)", "dark": "oklch(0.75 0.18 75)" }
    },
    "priority": {
      "critical": { "light": "oklch(0.55 0.22 25)", "dark": "oklch(0.65 0.22 25)" },
      "high": { "light": "oklch(0.65 0.18 55)", "dark": "oklch(0.75 0.18 55)" },
      "medium": { "light": "oklch(0.50 0.20 260)", "dark": "oklch(0.65 0.20 260)" },
      "low": { "light": "oklch(0.55 0.02 250)", "dark": "oklch(0.58 0.02 250)" }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "Geist, ui-sans-serif, system-ui, sans-serif",
      "mono": "Geist Mono, SFMono-Regular, monospace"
    },
    "fontSize": {
      "xs": "12px",
      "sm": "13px",
      "md": "14px",
      "lg": "16px",
      "xl": "18px",
      "2xl": "22px",
      "3xl": "28px"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px"
  },
  "radius": {
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "12px"
  },
  "elevation": {
    "none": { "border": "border-subtle", "shadow": "none" },
    "subtle": { "border": "border", "shadow": "0 1px 2px oklch(0.14 0.02 250 / 0.05)" },
    "raised": { "border": "border", "shadow": "0 1px 3px oklch(0.14 0.02 250 / 0.06), 0 1px 2px oklch(0.14 0.02 250 / 0.04)" },
    "overlay": { "border": "border-strong", "shadow": "0 4px 12px oklch(0.14 0.02 250 / 0.08), 0 1px 3px oklch(0.14 0.02 250 / 0.06)" }
  },
  "forbidden": {
    "patterns": [
      "backdrop-filter",
      "backdrop-blur",
      "rgba(",
      "--glass-",
      "--gradient-",
      "--blur-glass",
      "glass-card",
      "glass-shimmer",
      "gradient-morning",
      "gradient-ocean",
      "gradient-forest",
      "gradient-sunset",
      "gradient-twilight",
      "gradient-neutral",
      "rounded-[24px]",
      "rounded-[28px]",
      "rounded-[30px]"
    ]
  }
}
